🔷 Concept 4 — Nested dictionariespython# Dictionary inside a dictionary — each test has multiple fields
results = {
    "RRC_Setup": {                              # key = test name, value = another dictionary
        "rsrp": -85.0,                         # nested key: rsrp value
        "status": "PASS",                      # nested key: status
        "duration_ms": 45                      # nested key: how long test took
    },
    "Handover": {
        "rsrp": -103.5,
        "status": "FAIL",
        "duration_ms": 120
    }
}

print(results["RRC_Setup"]["rsrp"])             # access nested value — first key then second key
# Output: -85.0

print(results["Handover"]["status"])            # prints: FAIL

